<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- iCloud同期の有効/無効。entitlementsを外している間(Personal Team実機テスト)はfalse。
	     Developer Program承認後にentitlements復元とセットでtrueに戻すこと -->
	<key>AshiatoCloudEnabled</key>
	<false/>
	<!-- 対応言語は日本語のみ。DatePicker等のシステムUIも日本語表示にする -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>ja</string>
	</array>
	<key>CFBundleAllowMixedLocalizations</key>
	<true/>
</dict>
</plist>
